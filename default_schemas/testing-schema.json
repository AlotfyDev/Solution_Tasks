{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "testing-schema.json",
  "title": "TD Testing Task Schema",
  "description": "Default schema for test sub-tasks derived from TD (Test Design) markdown specifications.",
  "type": "object",
  "required": ["sub_task_id", "sequence", "hierarchy_level", "source", "metadata", "task", "traceability", "status"],

  "definitions": {
    "line_range": {
      "type": "array", "items": { "type": "integer", "minimum": 1 },
      "minItems": 2, "maxItems": 2
    },
    "scenario_ref": {
      "type": "object", "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["positive", "negative", "production", "thread_safety", "edge_case"] }
      }
    },
    "test_case_ref": {
      "type": "object", "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "framework": { "type": "string", "enum": ["gtest", "native_unit_test"] },
        "fixture": { "type": "string" },
        "status": { "type": "string", "enum": ["template", "implemented", "passing", "failing"] }
      }
    },
    "test_file_ref": {
      "type": "object", "required": ["path", "change_type", "test_cases"],
      "properties": {
        "path": { "type": "string" },
        "change_type": { "type": "string", "enum": ["create", "modify", "delete"] },
        "framework": { "type": "string", "enum": ["gtest", "native_unit_test"] },
        "test_cases": { "type": "array", "items": { "$ref": "#/definitions/test_case_ref" }, "minItems": 1 }
      }
    },
    "dependency": {
      "type": "object", "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["hard", "soft"] }
      }
    }
  },

  "properties": {
    "sub_task_id": { "type": "string", "pattern": "^TD-[A-Z]+\\d+-\\d+(-\\d+)*$" },
    "sequence": { "type": "integer", "minimum": 1 },
    "hierarchy_level": { "type": "integer", "minimum": 1, "maximum": 10 },

    "source": {
      "type": "object", "required": ["file", "relative_path", "lines", "section_title"],
      "properties": {
        "file": { "type": "string" },
        "relative_path": { "type": "string" },
        "lines": { "$ref": "#/definitions/line_range" },
        "section_title": { "type": "string" },
        "section_markdown": { "type": "string" }
      }
    },

    "metadata": {
      "type": "object",
      "required": ["phase", "test_level", "parent_aa", "parent_td"],
      "properties": {
        "phase": { "type": "integer", "minimum": 0, "maximum": 9 },
        "test_level": { "type": "string", "enum": ["unit", "integration", "benchmark", "emergency", "thread_safety"] },
        "parent_aa": { "type": "string" },
        "parent_aa_title": { "type": "string" },
        "parent_td": { "type": "string" },
        "aa_dependencies": { "type": "array", "items": { "$ref": "#/definitions/dependency" } },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },

    "task": {
      "type": "object",
      "required": ["title", "description", "scenarios", "files_to_modify", "acceptance_criteria"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "implementation_notes": { "type": "string" },
        "scenarios": { "type": "array", "items": { "$ref": "#/definitions/scenario_ref" }, "minItems": 1 },
        "files_to_modify": { "type": "array", "items": { "$ref": "#/definitions/test_file_ref" }, "minItems": 1 },
        "acceptance_criteria": {
          "type": "array", "items": {
            "type": "object", "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^TC-\\d+$" },
              "description": { "type": "string" },
              "verified_by": { "type": "string" }
            }
          }, "minItems": 1
        }
      }
    },

    "traceability": {
      "type": "object", "required": ["aa_reference", "td_reference"],
      "properties": {
        "aa_reference": { "type": "string" },
        "aa_sub_task_ids": { "type": "array", "items": { "type": "string" } },
        "td_reference": { "type": "string" },
        "td_section": { "type": "string" }
      }
    },

    "status": {
      "type": "object", "required": ["state"],
      "properties": {
        "state": { "type": "string", "enum": ["pending", "in_progress", "completed", "blocked", "cancelled"] },
        "assigned_to": { "type": "string" },
        "verification": {
          "type": "object",
          "properties": {
            "compiles": { "type": "boolean" },
            "tests_pass": { "type": "boolean" },
            "coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },

    "children": { "type": "array", "items": { "$ref": "#" } },
    "notes": { "type": "array", "items": {
      "type": "object", "required": ["date", "text"],
      "properties": {
        "date": { "type": "string" },
        "text": { "type": "string" },
        "author": { "type": "string" }
      }
    }}
  }
}
